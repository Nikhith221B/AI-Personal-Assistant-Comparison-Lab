# Deployment: local (full comparison) | spaces (OSS-only public demo)
# Hugging Face Space: set DEPLOYMENT_MODE=spaces in Space Variables (Repository secrets).
# Do NOT add GEMINI_API_KEY on the Space.
DEPLOYMENT_MODE=local

# Rolling memory default (2-12 exchanges); slider overrides per session
MAX_MEMORY_TURNS=8

# Frontier assistant (local only; not used on Hugging Face Spaces)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REQUEST_TIMEOUT_SECONDS=60

# OSS generation timeout (seconds)
OSS_GENERATION_TIMEOUT_SECONDS=120
